DATABASE_URL=mongodb://127.0.0.1/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE
WORDPRESS_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE

# Comma-separated origins allowed for CORS (required when requests use credentials). Set in all environments.
# Dev example (API on :3000, app on :3001): http://localhost:3000,http://localhost:3001
# Production: https://yourapp.com,https://admin.yourapp.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Server URL used by Payload for cookie domain, CSRF, and self-referencing URLs
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Cookie settings for cross-origin auth
# Set COOKIE_SAMESITE=None for cross-site production deploys (requires Secure)
COOKIE_DOMAIN=
COOKIE_SAMESITE=Lax
